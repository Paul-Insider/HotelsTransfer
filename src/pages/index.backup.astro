---
import MainLayout from "../layouts/Layout.astro";
---

<MainLayout>
  <main class="home">
    <section class="hero">
      <header class="nav">
        <a class="brand" href="/">
          <span>HotelsTransfer</span>
          <small>Airport transfers worldwide</small>
        </a>

        <nav>
          <a href="#">Destinations</a>
          <a href="#">Airports</a>
          <a href="#">Companies</a>
          <a href="#">How it works</a>
        </nav>

        <div class="navActions">
          <a href="#">Login</a>
          <a class="button" href="#">Book now</a>
        </div>
      </header>

      <div class="heroContent">
        <p class="eyebrow">Verified airport transfers worldwide</p>

<h1>
  Your arrival,
  <span>already arranged.</span>
</h1>

<p class="lead">
  Compare trusted transfer companies, transparent prices and premium vehicles
  anywhere in the world.
</p>

        <form class="searchCard">
          <label>
            <span>Pickup airport</span>
            <input placeholder="Select pickup airport" />
          </label>

          <label>
            <span>Destination</span>
            <input placeholder="Hotel, address or destination" />
          </label>

          <label>
            <span>Date</span>
            <input type="date" />
          </label>

          <button type="button">Find my transfer</button>
        </form>
      </div>
    </section>

	<section class="trustStrip">
  <div>
    <strong>Verified operators</strong>
    <span>Every company is reviewed before appearing on the platform.</span>
  </div>

  <div>
    <strong>Transparent prices</strong>
    <span>Compare real transfer prices without hidden surprises.</span>
  </div>

  <div>
    <strong>Worldwide coverage</strong>
    <span>Airport transportation across the world’s leading destinations.</span>
  </div>

  <div>
    <strong>Secure booking</strong>
    <span>Your reservation and personal information remain protected.</span>
  </div>
</section>

    <section class="section">
      <div class="sectionHeader">
        <div>
          <p class="eyebrow">Popular routes</p>
          <h2>Start with the world’s most searched airports</h2>
        </div>
        <a href="#">View all airports</a>
      </div>

      <div class="grid">
        {
          [
  {
    city: "Cancun",
    code: "CUN",
    country: "Mexico",
    price: "$35",
    providers: "86 verified providers",
    image: "/images/destinations/cancun.webp",
  },
  {
    city: "Paris",
    code: "CDG",
    country: "France",
    price: "$56",
    providers: "98 verified providers",
    image: "/images/destinations/paris.webp",
  },
  {
    city: "London",
    code: "LHR",
    country: "United Kingdom",
    price: "$48",
    providers: "124 verified providers",
    image: "/images/destinations/london.webp",
  },
  {
    city: "Dubai",
    code: "DXB",
    country: "United Arab Emirates",
    price: "$41",
    providers: "112 verified providers",
    image: "/images/destinations/dubai.webp",
  },
  {
    city: "New York",
    code: "JFK",
    country: "United States",
    price: "$52",
    providers: "101 verified providers",
    image: "/images/destinations/new-york.webp",
  },
  {
    city: "Singapore",
    code: "SIN",
    country: "Singapore",
    price: "$45",
    providers: "74 verified providers",
    image: "/images/destinations/singapore.webp",
  },
].map((item) => (
  <a class="card" href={`/destinations/${item.city.toLowerCase().replaceAll(" ", "-")}`}>
    <div
      class="cardImage"
      style={`background-image:
        linear-gradient(
          180deg,
          rgba(7, 18, 31, 0.02) 30%,
          rgba(7, 18, 31, 0.42) 100%
        ),
        url("${item.image}")`}
    >
      <div class="cardTop">
        <span class="airportCode">{item.code}</span>
      </div>

      <div class="cardImageContent">
        <span>{item.country}</span>
      </div>
    </div>

    <div class="cardBody">
      <div class="cardHeading">
        <h3>{item.city}</h3>
        <span class="cardArrow">↗</span>
      </div>

      <div class="cardMeta">
        <div>
          <small>Transfers from</small>
          <strong>{item.price}</strong>
        </div>

        <div>
          <small>Available network</small>
          <strong>{item.providers}</strong>
        </div>
      </div>
    </div>
  </a>
))
        }
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .hero {
  position: relative;
  min-height: 680px;
  padding: 24px 28px 42px;
  overflow: hidden;

  background:
    linear-gradient(
      180deg,
      rgba(13, 10, 8, 0.34) 0%,
      rgba(10, 15, 22, 0.12) 35%,
      rgba(8, 17, 29, 0.28) 68%,
      rgba(8, 17, 29, 0.58) 100%
    ),
    url("/images/hero/hero-global-mobility.webp")
      center center / cover no-repeat;
}

  .nav {
  position: relative;
  z-index: 2;

  max-width: 1360px;
  height: 68px;
  margin: 0 auto;
  padding: 0 22px;

  display: flex;
  align-items: center;
  justify-content: space-between;

  color: white;

  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 18px;

  background: rgba(18, 23, 29, 0.18);

  box-shadow:
    0 14px 45px rgba(5, 12, 20, 0.12),
    inset 0 1px 0 rgba(255, 255, 255, 0.12);

  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

  .brand {
  display: grid;
  gap: 1px;

  color: white;
  font-weight: 800;
  letter-spacing: -0.035em;
}

  .brand small {
    font-size: 11px;
    font-weight: 500;
    opacity: 0.75;
    letter-spacing: 0;
  }

  .nav nav,
  .navActions {
    display: flex;
    align-items: center;
    gap: 26px;
    font-size: 14px;
    font-weight: 600;
  }

  .button {
  padding: 11px 17px;
  border-radius: 999px;

  color: #101827;
  background: rgba(255, 255, 255, 0.95);

  font-size: 13px;
  font-weight: 800;

  box-shadow: 0 8px 24px rgba(6, 16, 28, 0.14);
}

  .heroContent {
  position: relative;
  z-index: 1;

  max-width: 1120px;
  margin: 82px auto 0;

  text-align: center;
  color: white;
}

  .eyebrow {
  margin: 0 0 15px;

  font-size: 11px;
  font-weight: 850;
  line-height: 1.4;
  letter-spacing: 0.17em;
  text-transform: uppercase;
}

  h1 {
  max-width: 850px;
  margin: 0 auto;

  font-size: clamp(54px, 6vw, 82px);
  font-weight: 760;
  line-height: 0.94;
  letter-spacing: -0.065em;

  text-wrap: balance;
}

h1 span {
  display: block;
  margin-top: 4px;

  font-family: Georgia, "Times New Roman", serif;
  font-weight: 400;
  font-style: italic;
  letter-spacing: -0.045em;
}

  .lead {
  max-width: 620px;
  margin: 22px auto 32px;

  font-size: 17px;
  line-height: 1.55;

  opacity: 0.9;
}

  .searchCard {
  max-width: 1180px;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1.2fr 1.2fr 0.72fr 190px;
  gap: 9px;

  padding: 10px;

  border: 1px solid rgba(255, 255, 255, 0.62);
  border-radius: 22px;

  background: rgba(255, 255, 255, 0.9);

  box-shadow:
    0 28px 70px rgba(7, 17, 29, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.85);

  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

  .searchCard label {
  min-width: 0;
  padding: 14px 16px;

  text-align: left;

  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 14px;

  background: rgba(255, 255, 255, 0.94);

  transition:
    border-color 180ms ease,
    box-shadow 180ms ease;
}

.searchCard label:focus-within {
  border-color: rgba(11, 78, 162, 0.35);
  box-shadow: 0 0 0 4px rgba(11, 78, 162, 0.08);
}

  .searchCard span {
  display: block;
  margin-bottom: 5px;

  color: #718096;

  font-size: 9px;
  font-weight: 850;
  letter-spacing: 0.13em;
  text-transform: uppercase;
}

  .searchCard input {
  width: 100%;
  min-width: 0;

  border: 0;
  outline: 0;

  color: #172033;
  background: transparent;

  font-size: 14px;
  font-weight: 700;
}

  .searchCard button {
  min-height: 58px;

  border: 0;
  border-radius: 14px;

  color: white;

  background:
    linear-gradient(135deg, #155ab1 0%, #0b438d 100%);

  box-shadow: 0 12px 28px rgba(10, 67, 141, 0.28);

  font-size: 14px;
  font-weight: 850;

  cursor: pointer;

  transition:
    transform 180ms ease,
    box-shadow 180ms ease;
}

.searchCard button:hover {
  transform: translateY(-1px);
  box-shadow: 0 16px 34px rgba(10, 67, 141, 0.34);
}

  .section {
  max-width: 1320px;
  margin: 68px auto 96px;
  padding: 0 28px;
}

  .sectionHeader {
  margin-bottom: 30px;

  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 30px;
}

  .sectionHeader .eyebrow {
    color: var(--blue);
  }

  h2 {
  max-width: 620px;
  margin: 0;

  font-size: clamp(34px, 4vw, 50px);
  font-weight: 760;
  line-height: 0.98;
  letter-spacing: -0.055em;
}

  .sectionHeader a {
    color: var(--blue);
    font-weight: 800;
  }

  .grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

  .card {
  display: block;
  overflow: hidden;

  color: var(--text);

  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 20px;

  background: white;

  box-shadow:
    0 12px 36px rgba(15, 23, 42, 0.055);

  transition:
    transform 220ms ease,
    box-shadow 220ms ease,
    border-color 220ms ease;
}

.card:hover {
  transform: translateY(-5px);

  border-color: rgba(11, 78, 162, 0.16);

  box-shadow:
    0 24px 58px rgba(15, 23, 42, 0.12);
}

.cardImage {
  position: relative;
  height: 210px;

  display: flex;
  flex-direction: column;
  justify-content: space-between;

  padding: 16px;

  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;

  transition: background-size 420ms ease;
}

.card:hover .cardImage {
  background-size: 104%;
}

.cardTop {
  display: flex;
  justify-content: flex-end;
}

.airportCode {
  padding: 7px 10px;

  color: #10233e;
  background: rgba(255, 255, 255, 0.92);

  border: 1px solid rgba(255, 255, 255, 0.75);
  border-radius: 999px;

  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.06em;

  box-shadow: 0 8px 22px rgba(9, 20, 35, 0.15);

  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.cardImageContent {
  color: white;
}

.cardImageContent span {
  font-size: 12px;
  font-weight: 750;
  letter-spacing: 0.03em;

  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.38);
}

.cardBody {
  padding: 20px 22px 22px;
}

.cardHeading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
}

.cardHeading h3 {
  margin: 0;

  font-size: 23px;
  font-weight: 790;
  letter-spacing: -0.045em;
}

.cardArrow {
  width: 34px;
  height: 34px;

  display: grid;
  place-items: center;

  border-radius: 50%;

  color: var(--blue);
  background: #eff6ff;

  font-size: 15px;
  font-weight: 900;

  transition:
    transform 200ms ease,
    color 200ms ease,
    background 200ms ease;
}

.card:hover .cardArrow {
  transform: translate(2px, -2px);

  color: white;
  background: var(--blue);
}

.cardMeta {
  margin-top: 22px;

  display: grid;
  grid-template-columns: 0.8fr 1.2fr;
  gap: 18px;
}

.cardMeta > div {
  display: grid;
  gap: 5px;
}

.cardMeta small {
  color: var(--muted);

  font-size: 10px;
  font-weight: 750;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.cardMeta strong {
  color: #132038;

  font-size: 14px;
  font-weight: 800;
}

.trustStrip {
  position: relative;
  z-index: 3;

  max-width: 1240px;
  margin: -28px auto 0;
  padding: 22px 26px;

  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28px;

  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 20px;

  background: rgba(255, 255, 255, 0.96);

  box-shadow:
    0 20px 55px rgba(15, 23, 42, 0.1);

  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.trustStrip div {
  position: relative;
  padding-left: 18px;
}

.trustStrip div::before {
  content: "";

  position: absolute;
  top: 5px;
  left: 0;

  width: 7px;
  height: 7px;

  border-radius: 50%;
  background: var(--blue);

  box-shadow: 0 0 0 5px rgba(11, 78, 162, 0.08);
}

.trustStrip strong {
  display: block;
  margin-bottom: 6px;

  font-size: 13px;
  font-weight: 850;
}

.trustStrip span {
  display: block;

  color: var(--muted);

  font-size: 11px;
  line-height: 1.55;
}

  @media (max-width: 900px) {
  .hero {
    min-height: 900px;
    padding: 16px;

    background:
      linear-gradient(
        180deg,
        rgba(18, 10, 6, 0.46) 0%,
        rgba(12, 16, 20, 0.14) 33%,
        rgba(8, 16, 26, 0.1) 57%,
        rgba(8, 16, 26, 0.72) 100%
      ),
      url("/images/hero/hero-global-mobility-mobile.webp")
        center top / cover no-repeat;
  }

  .nav {
    height: 62px;
    padding: 0 17px;
    border-radius: 17px;
  }

  .nav nav {
    display: none;
  }

  .navActions {
    display: flex;
  }

  .navActions > a:first-child {
    display: none;
  }

  .brand small {
    display: none;
  }

  .brand span {
    font-size: 16px;
  }

  .button {
    padding: 10px 14px;
    font-size: 12px;
  }

  .heroContent {
    margin-top: 68px;
  }

  .eyebrow {
    max-width: 290px;
    margin: 0 auto 14px;
    font-size: 9px;
  }

  h1 {
    max-width: 360px;
    font-size: clamp(46px, 13vw, 60px);
    line-height: 0.92;
  }

  .lead {
    max-width: 340px;
    margin: 21px auto 270px;
    padding: 0 8px;
    font-size: 15px;
  }

  .searchCard {
    grid-template-columns: 1fr;
    gap: 8px;

    padding: 9px;
    border-radius: 21px;
  }

  .searchCard label {
    padding: 13px 15px;
    border-radius: 14px;
  }

  .searchCard button {
    min-height: 55px;
    border-radius: 14px;
  }

  .section {
    margin-top: 54px;
    padding: 0 18px;
  }

  .sectionHeader {
    align-items: flex-start;
    flex-direction: column;
  }

  .grid {
    grid-template-columns: 1fr;
  }
  .trustStrip {
    margin: -18px 16px 0;
    padding: 20px;

    grid-template-columns: 1fr;
    gap: 20px;

    border-radius: 18px;
}
}
</style>