<section class="hero">
  <picture class="heroMedia">
    <source
      media="(max-width: 767px)"
      srcset="/images/hero/hero-global-mobility-mobile.webp"
    />

    <img
      src="/images/hero/hero-global-mobility.webp"
      alt=""
      width="2400"
      height="1350"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  <div class="heroOverlay"></div>

  <header class="nav">
    <a class="brand" href="/" aria-label="HotelsTransfer home">
      <span>HotelsTransfer</span>
      <small>Airport transfers worldwide</small>
    </a>

    <nav aria-label="Primary navigation">
      <a href="/destinations">Destinations</a>
      <a href="/airports">Airports</a>
      <a href="/companies">Companies</a>
      <a href="/how-it-works">How it works</a>
    </nav>

    <div class="navActions">
      <a class="login" href="/login">Log in</a>
      <a class="bookButton" href="#transfer-search">Book now</a>
    </div>
  </header>

  <div class="heroContent">
    <p class="eyebrow">Verified airport transfers worldwide</p>

    <h1>
      Your arrival,
      <span>already arranged.</span>
    </h1>

    <p class="lead">
      Compare trusted transfer companies, transparent prices and premium
      vehicles anywhere in the world.
    </p>

    <form id="transfer-search" class="searchCard">
      <label>
        <span>Pickup airport</span>
        <input
          type="search"
          name="pickup"
          placeholder="Select pickup airport"
          autocomplete="off"
        />
      </label>

      <label>
        <span>Destination</span>
        <input
          type="search"
          name="destination"
          placeholder="Hotel, address or destination"
          autocomplete="off"
        />
      </label>

      <label>
        <span>Date</span>
        <input type="date" name="date" />
      </label>

      <label>
        <span>Passengers</span>
        <select name="passengers">
          <option value="1">1 passenger</option>
          <option value="2">2 passengers</option>
          <option value="3">3 passengers</option>
          <option value="4">4 passengers</option>
          <option value="5">5+ passengers</option>
        </select>
      </label>

      <button type="submit">Find my transfer</button>
    </form>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 680px;
    padding: 24px 28px 44px;
    overflow: hidden;
    isolation: isolate;
    background: #15202c;
  }

  .heroMedia {
    position: absolute;
    inset: 0;
    z-index: -3;
  }

  .heroMedia,
  .heroMedia img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .heroMedia img {
    object-fit: cover;
    object-position: center;
  }

  .heroOverlay {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(
        180deg,
        rgba(13, 10, 8, 0.34) 0%,
        rgba(10, 15, 22, 0.1) 35%,
        rgba(8, 17, 29, 0.26) 68%,
        rgba(8, 17, 29, 0.62) 100%
      );
  }

  .nav {
    position: relative;
    z-index: 2;
    max-width: 1360px;
    height: 68px;
    margin: 0 auto;
    padding: 0 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 18px;
    background: rgba(18, 23, 29, 0.18);
    box-shadow:
      0 14px 45px rgba(5, 12, 20, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: grid;
    gap: 1px;
    color: white;
    font-weight: 800;
    letter-spacing: -0.035em;
  }

  .brand span {
    font-size: 18px;
  }

  .brand small {
    font-size: 9px;
    font-weight: 650;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.58;
  }

  .nav nav,
  .navActions {
    display: flex;
    align-items: center;
    gap: 27px;
    font-size: 13px;
    font-weight: 650;
  }

  .nav nav a,
  .login {
    color: white;
    opacity: 0.9;
  }

  .bookButton {
    padding: 11px 17px;
    border-radius: 999px;
    color: #101827;
    background: rgba(255, 255, 255, 0.96);
    font-size: 13px;
    font-weight: 800;
  }

  .heroContent {
    position: relative;
    z-index: 1;
    max-width: 1220px;
    margin: 80px auto 0;
    text-align: center;
    color: white;
  }

  .eyebrow {
    margin: 0 0 15px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 850px;
    margin: 0 auto;
    font-size: clamp(54px, 6vw, 82px);
    line-height: 0.94;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  h1 span {
    display: block;
    margin-top: 4px;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.045em;
  }

  .lead {
    max-width: 620px;
    margin: 22px auto 32px;
    font-size: 17px;
    line-height: 1.55;
    opacity: 0.92;
  }

  .searchCard {
    display: grid;
    grid-template-columns:
      minmax(190px, 1.2fr)
      minmax(190px, 1.2fr)
      minmax(140px, 0.68fr)
      minmax(140px, 0.68fr)
      190px;
    gap: 9px;
    padding: 10px;
    border: 1px solid rgba(255, 255, 255, 0.62);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.91);
    box-shadow: 0 28px 70px rgba(7, 17, 29, 0.3);
    backdrop-filter: blur(24px);
  }

  .searchCard label {
    min-width: 0;
    padding: 14px 15px;
    text-align: left;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.95);
  }

  .searchCard label > span {
    display: block;
    margin-bottom: 5px;
    color: #718096;
    font-size: 9px;
    font-weight: 850;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .searchCard input,
  .searchCard select {
    width: 100%;
    min-width: 0;
    border: 0;
    outline: 0;
    color: #172033;
    background: transparent;
    font: inherit;
    font-size: 13px;
    font-weight: 700;
  }

  .searchCard button {
    min-height: 58px;
    border: 0;
    border-radius: 14px;
    color: white;
    background: linear-gradient(135deg, #155ab1, #0b438d);
    font-size: 13px;
    font-weight: 850;
    cursor: pointer;
  }

  @media (max-width: 1120px) {
    .nav nav {
      display: none;
    }

    .searchCard {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .searchCard button {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 920px;
      padding: 14px 14px 30px;
    }

    .heroMedia img {
      object-position: center top;
    }

    .heroOverlay {
      background:
        linear-gradient(
          180deg,
          rgba(17, 9, 5, 0.5) 0%,
          rgba(12, 15, 20, 0.1) 30%,
          rgba(8, 16, 26, 0.08) 56%,
          rgba(8, 16, 26, 0.78) 100%
        );
    }

    .nav {
      height: 62px;
      padding: 0 16px;
      border-radius: 17px;
    }

    .brand span {
      font-size: 16px;
    }

    .brand small,
    .login {
      display: none;
    }

    .bookButton {
      padding: 10px 14px;
      font-size: 12px;
    }

    .heroContent {
      margin-top: 66px;
    }

    .eyebrow {
      font-size: 9px;
    }

    h1 {
      max-width: 360px;
      font-size: clamp(46px, 13vw, 60px);
    }

    .lead {
      max-width: 340px;
      margin: 21px auto 270px;
      font-size: 15px;
    }

    .searchCard {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 9px;
    }

    .searchCard button {
      grid-column: auto;
    }
  }
</style>
