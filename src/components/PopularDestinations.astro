---
import { destinations } from "../data/destinations";
---

<section class="destinations" aria-labelledby="destinations-title">
  <header class="sectionHeader">
    <div class="sectionIntro">
      <p class="eyebrow">Curated destinations</p>

      <h2 id="destinations-title">
        Exceptional arrivals,
        <span>wherever the world takes you.</span>
      </h2>

      <p class="sectionDescription">
        Compare verified transfer partners across the world’s most requested
        destinations.
      </p>
    </div>

    <a class="viewAll" href="/destinations">
      View all destinations

      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M7 17 17 7M8 7h9v9"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </header>

  <div class="destinationGrid">
    {
      destinations.map((destination) => (
        <a
          class="destinationCard"
          href={`/destinations/${destination.slug}`}
          aria-label={`View airport transfers in ${destination.city}`}
        >
          <div class="media">
            <div class="fallbackCode" aria-hidden="true">
              {destination.code}
            </div>

            <img
              src={destination.image}
              alt={`${destination.city}, ${destination.country}`}
              width="900"
              height="650"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              sizes="
                (max-width: 620px) calc(100vw - 32px),
                (max-width: 960px) 50vw,
                (max-width: 1220px) 33vw,
                25vw
              "
            />

            <div class="mediaShade"></div>

            <div class="mediaTop">
              <span class="airportCode">{destination.code}</span>

              <span class="verifiedBadge">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M12 3 5.5 5.6v5.2c0 4.3 2.7 8.1 6.5 9.4 3.8-1.3 6.5-5.1 6.5-9.4V5.6L12 3Z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linejoin="round"
                  />
                  <path
                    d="m9.2 11.8 1.8 1.8 3.8-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>

                Verified partners
              </span>
            </div>

            <div class="mediaTitle">
              <p>{destination.country}</p>
              <h3>{destination.city}</h3>
            </div>
          </div>

          <div class="cardContent">
            <div class="confidence confidencePartnersOnly">
              <div class="confidenceItem partnersOnlyItem">
                <svg class="shield" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M12 3 5.5 5.6v5.2c0 4.3 2.7 8.1 6.5 9.4 3.8-1.3 6.5-5.1 6.5-9.4V5.6L12 3Z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linejoin="round"
                  />
                  <path
                    d="m9.2 11.8 1.8 1.8 3.8-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>

                <strong>{destination.partners}</strong>

                <span class="desktopPartnerLabel">
                  Verified transfer partners
                </span>

                <span class="mobilePartnerLabel">
                  Verified partners
                </span>
              </div>
            </div>

            <div class="serviceList" aria-label="Included transfer services">
              {
                destination.services.map((service) => (
                  <span class="servicePill">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path
                        d="m7.5 12.2 3 3 6-6.4"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.9"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>

                    {service}
                  </span>
                ))
              }
            </div>

            <footer class="cardFooter">
              <div class="price">
                <span>Transfers from</span>

                <strong>
                  ${destination.price}
                  <small>{destination.currency}</small>
                </strong>
              </div>

              <span class="compare">
                <span class="desktopCompare">Compare transfers</span>
                <span class="mobileCompare">View transfers</span>

                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="m9 18 6-6-6-6"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </footer>
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .destinations {
    max-width: 1400px;
    margin: 82px auto 64px;
    padding: 0 30px;
  }

  .sectionHeader {
    margin-bottom: 36px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .sectionIntro {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 13px;
    color: var(--blue);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    color: #101827;
    font-size: clamp(40px, 4.25vw, 58px);
    font-weight: 750;
    line-height: 0.96;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  h2 span {
    display: block;
    color: #687386;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.045em;
  }

  .sectionDescription {
    max-width: 600px;
    margin: 19px 0 0;
    color: #687386;
    font-size: 15px;
    line-height: 1.65;
  }

  .viewAll {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 4px;
    color: #183f70;
    border-bottom: 1px solid rgba(24, 63, 112, 0.22);
    font-size: 13px;
    font-weight: 800;
  }

  .viewAll svg {
    width: 16px;
    height: 16px;
  }

  .destinationGrid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .destinationCard {
    min-width: 0;
    display: block;
    overflow: hidden;
    color: #111b2d;
    border: 1px solid rgba(15, 23, 42, 0.075);
    border-radius: 24px;
    background: #fff;
    box-shadow:
      0 2px 4px rgba(15, 23, 42, 0.02),
      0 16px 42px rgba(15, 23, 42, 0.06);
    content-visibility: auto;
    contain-intrinsic-size: 475px;
    transition:
      transform 260ms cubic-bezier(0.2, 0.75, 0.25, 1),
      border-color 260ms ease,
      box-shadow 260ms ease;
  }

  .destinationCard:hover {
    transform: translateY(-5px);
    border-color: rgba(29, 75, 134, 0.15);
    box-shadow:
      0 3px 6px rgba(15, 23, 42, 0.025),
      0 28px 65px rgba(15, 23, 42, 0.12);
  }

  .media {
    position: relative;
    aspect-ratio: 1.12 / 1;
    overflow: hidden;
    background:
      radial-gradient(circle at 20% 15%, #f3ede3, transparent 46%),
      linear-gradient(145deg, #f3f6f8, #e7ecef);
  }

  .fallbackCode {
    position: absolute;
    right: -10px;
    bottom: -24px;
    color: rgba(19, 36, 61, 0.055);
    font-size: 90px;
    font-weight: 900;
    letter-spacing: -0.08em;
  }

  .media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 650ms cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  .destinationCard:hover .media img {
    transform: scale(1.03);
  }

  . {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        rgba(7, 14, 24, 0.14) 0%,
        transparent 42%,
        rgba(7, 14, 24, 0.72) 100%
      );
  }

  .mediaTop {
    position: absolute;
    top: 14px;
    left: 14px;
    right: 14px;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .airportCode,
  .verifiedBadge {
    min-height: 31px;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 8px 20px rgba(5, 16, 29, 0.13);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .airportCode {
    padding: 0 11px;
    color: #162944;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.09em;
  }

  .verifiedBadge {
    gap: 6px;
    padding: 0 10px;
    color: #263b55;
    font-size: 9px;
    font-weight: 800;
    letter-mediaShadespacing: 0.045em;
    text-transform: uppercase;
  }

  .verifiedBadge svg {
    width: 14px;
    height: 14px;
  }

  .mediaTitle {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 18px;
    z-index: 3;
    color: white;
  }

  .mediaTitle p {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 750;
    letter-spacing: 0.055em;
    text-transform: uppercase;
    opacity: 0.9;
  }

  .mediaTitle h3 {
    margin: 0;
    font-size: 31px;
    font-weight: 760;
    line-height: 0.98;
    letter-spacing: -0.055em;
    text-shadow: 0 3px 18px rgba(0, 0, 0, 0.38);
  }

  .cardContent {
    padding: 19px 20px 20px;
  }

  .confidence {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
}

  .confidenceItem {
    min-width: 0;
    display: flex;
    align-items: flex-start;
    gap: 9px;
  }

  .confidenceItem > svg {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    margin-top: 2px;
  }

  .star {
    color: #b78a3e;
  }

  .shield {
    color: #315b8c;
  }

  .confidenceItem strong {
    display: block;
    color: #111b2d;
    font-size: 17px;
    font-weight: 850;
    line-height: 1;
  }

  .confidenceItem span {
    display: block;
    margin-top: 5px;
    color: #778294;
    font-size: 10px;
    font-weight: 650;
    line-height: 1.3;
    white-space: nowrap;
  }

  .serviceLine {
    margin-top: 17px;
    padding: 14px 0;
    display: flex;
    align-items: center;
    gap: 8px;
    color: #526071;
    border-top: 1px solid rgba(15, 23, 42, 0.065);
    border-bottom: 1px solid rgba(15, 23, 42, 0.065);
    font-size: 11px;
    font-weight: 700;
    line-height: 1.35;
  }

  .serviceLine svg {
    flex: 0 0 auto;
    width: 17px;
    height: 17px;
    color: #315b8c;
  }

  .cardFooter {
    margin-top: 17px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }

  .price {
    display: grid;
    gap: 4px;
  }

  .price > span {
    color: #7b8493;
    font-size: 9px;
    font-weight: 780;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .price strong {
    color: #101827;
    font-size: 29px;
    font-weight: 820;
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .price small {
    margin-left: 3px;
    color: #7b8493;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .compare {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding-bottom: 3px;
    color: #183f70;
    border-bottom: 1px solid rgba(24, 63, 112, 0.22);
    font-size: 11px;
    font-weight: 850;
    white-space: nowrap;
    transition:
      color 200ms ease,
      gap 200ms ease;
  }

  .compare svg {
    width: 15px;
    height: 15px;
  }

  .destinationCard:hover .compare {
    gap: 8px;
    color: #0f315d;
  }


  .serviceLine {
    display: none;
  }

  .serviceList {
    margin-top: 17px;
    padding: 15px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    border-top: 1px solid rgba(15, 23, 42, 0.065);
    border-bottom: 1px solid rgba(15, 23, 42, 0.065);
  }

  .servicePill {
    min-height: 30px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0 10px;
    color: #435268;
    border: 1px solid rgba(31, 63, 101, 0.1);
    border-radius: 999px;
    background:
      linear-gradient(
        180deg,
        rgba(248, 250, 252, 0.98),
        rgba(243, 246, 249, 0.98)
      );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    font-size: 10px;
    font-weight: 720;
    line-height: 1;
    white-space: nowrap;
  }

  .servicePill svg {
    width: 13px;
    height: 13px;
    color: #2d5b8f;
  }

  .compare {
    min-height: 39px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 0 7px 0 14px;
    color: #183654;
    border: 1px solid rgba(24, 54, 84, 0.13);
    border-radius: 999px;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.98),
        rgba(247, 249, 251, 0.98)
      );
    box-shadow:
      0 8px 20px rgba(15, 23, 42, 0.055),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    font-size: 10px;
    font-weight: 820;
    white-space: nowrap;
    transition:
      color 200ms ease,
      border-color 200ms ease,
      box-shadow 200ms ease,
      transform 200ms ease;
  }

  .compare svg {
    width: 28px;
    height: 28px;
    padding: 7px;
    color: white;
    border-radius: 50%;
    background: #183f70;
    transition:
      background 200ms ease,
      transform 200ms ease;
  }

  .destinationCard:hover .compare {
    color: #0e315f;
    border-color: rgba(24, 63, 112, 0.24);
    box-shadow:
      0 12px 26px rgba(15, 23, 42, 0.09),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    transform: translateY(-1px);
  }

  .destinationCard:hover .compare svg {
    background: #0e315f;
    transform: translateX(2px);
  }

  @media (max-width: 1220px) {
    .destinationGrid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 960px) {
    .destinations {
      margin-top: 68px;
      padding-inline: 20px;
    }

    .sectionHeader {
      align-items: flex-start;
      flex-direction: column;
      gap: 20px;
    }

    .destinationGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .destinations {
      margin: 58px auto 82px;
      padding-inline: 16px;
    }

    .sectionHeader {
      margin-bottom: 26px;
    }

    h2 {
      font-size: clamp(38px, 11vw, 47px);
      line-height: 0.98;
    }

    .sectionDescription {
      margin-top: 17px;
      font-size: 14px;
      line-height: 1.6;
    }

    .viewAll {
      font-size: 12px;
    }

    .destinationGrid {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .destinationCard {
      border-radius: 22px;
    }

    .media {
      aspect-ratio: 1.16 / 1;
    }

    .mediaTitle h3 {
      font-size: 34px;
    }

    .cardContent {
      padding: 20px;
    }

    .confidence {
      grid-template-columns: 0.85fr 1.3fr;
      gap: 15px;
    }

    .confidenceItem strong {
      font-size: 14px;
    }

    .confidenceItem span {
      font-size: 11px;
    }

    .serviceLine {
      font-size: 12px;
    }

    .price strong {
      font-size: 28px;
    }

    .compare {
      font-size: 12px;
    }
  }

  @media (max-width: 370px) {
    .confidence {
      grid-template-columns: 0.85fr 1.3fr;
      gap: 14px;
    }

    .cardFooter {
      align-items: flex-start;
      flex-direction: column;
    }
  }


  @media (max-width: 620px) {
    .serviceList {
      gap: 8px;
    }

    .servicePill {
      min-height: 32px;
      padding-inline: 11px;
      font-size: 11px;
    }

    .cardFooter {
      margin-top: 18px;
    }

    .compare {
      min-height: 42px;
      padding-left: 15px;
      font-size: 11px;
    }

    .compare svg {
      width: 30px;
      height: 30px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .destinationCard,
    .media img,
    .compare {
      transition: none;
    }

    .destinationCard:hover,
    .destinationCard:hover .media img {
      transform: none;
    }
  }


  /* Partners-only destination confidence */
  .confidencePartnersOnly {
    display: block;
  }

  .partnersOnlyItem {
    display: grid;
    grid-template-columns: 18px auto;
    grid-template-rows: auto auto;
    align-items: center;
    justify-content: start;
    column-gap: 10px;
    row-gap: 7px;
    min-width: 0;
  }

  .partnersOnlyItem > .shield {
    grid-column: 1;
    grid-row: 1;
    width: 16px;
    height: 16px;
    margin: 0;
    color: #2f659f;
  }

  .partnersOnlyItem > strong {
    grid-column: 2;
    grid-row: 1;
    display: block;
    color: #111b2d;
    font-size: 17px;
    font-weight: 850;
    line-height: 1;
  }

  .partnersOnlyItem > .desktopPartnerLabel,
  .partnersOnlyItem > .mobilePartnerLabel {
    grid-column: 1 / -1;
    grid-row: 2;
    display: block;
    margin: 0;
    color: #778294;
    font-size: 10px;
    font-weight: 650;
    line-height: 1.3;
  }

  .mobilePartnerLabel {
    display: none !important;
  }

  @media (max-width: 620px) {
    .desktopPartnerLabel {
      display: none !important;
    }

    .mobilePartnerLabel {
      display: block !important;
    }

    .partnersOnlyItem {
      grid-template-columns: 16px auto;
      column-gap: 8px;
      row-gap: 6px;
    }

    .partnersOnlyItem > .shield {
      width: 15px;
      height: 15px;
    }

    .partnersOnlyItem > strong {
      font-size: 16px;
    }

    .partnersOnlyItem > .mobilePartnerLabel {
      font-size: 10px;
      white-space: normal;
    }
  }


  /* Mobile card typography refinement */
  @media (max-width: 620px) {
    /*
     * Les noms des villes restent sur une seule ligne.
     * La taille demeure premium, mais adaptée aux cartes en 2 colonnes.
     */
    .mediaTitle {
      left: 14px;
      right: 14px;
      bottom: 15px;
    }

    .mediaTitle h3 {
      max-width: 100%;
      font-size: 30px;
      line-height: 1;
      letter-spacing: -0.05em;
      white-space: nowrap;
    }

    /*
     * "Verified partners" doit rester sur une seule ligne.
     */
    .partnersOnlyItem > .mobilePartnerLabel {
      display: block !important;
      margin: 0;
      font-size: 9px;
      line-height: 1.15;
      letter-spacing: -0.01em;
      white-space: nowrap !important;
      overflow-wrap: normal !important;
      word-break: normal !important;
    }

    /*
     * Les services sont uniques et légèrement plus compacts.
     */
    .servicePill {
      min-height: 30px;
      padding-inline: 9px;
      gap: 5px;
      font-size: 9px;
      white-space: nowrap;
    }

    .servicePill svg {
      width: 12px;
      height: 12px;
    }
  }

  @media (max-width: 370px) {
    .mediaTitle h3 {
      font-size: 27px;
    }

    .partnersOnlyItem > .mobilePartnerLabel {
      font-size: 8.5px;
    }
  }


  /* Mobile partners single-line layout */
  @media (max-width: 620px) {
    .mediaTop .verifiedBadge {
      display: none;
    }

    .airportCode {
      min-height: 24px;
      padding: 0 8px;
      font-size: 9px;
      letter-spacing: 0.07em;
    }

    .partnersOnlyItem {
      display: flex;
      align-items: center;
      gap: 6px;
      min-width: 0;
      white-space: nowrap;
    }

    .partnersOnlyItem > .shield {
      flex: 0 0 auto;
      width: 13px;
      height: 13px;
      margin: 0;
    }

    .partnersOnlyItem > strong {
      flex: 0 0 auto;
      display: inline;
      font-size: 15px;
      line-height: 1;
    }

    .partnersOnlyItem > .desktopPartnerLabel {
      display: none !important;
    }

    .partnersOnlyItem > .mobilePartnerLabel {
      display: inline !important;
      margin: 0;
      font-size: 9px;
      line-height: 1;
      letter-spacing: -0.01em;
      white-space: nowrap !important;
      overflow-wrap: normal !important;
      word-break: normal !important;
    }
  }


  /* Mobile card proportion polish */
  @media (max-width: 620px) {
    /*
     * La photo devient dominante.
     * Objectif visuel : environ 58% photo / 42% contenu.
     */
    .media {
      aspect-ratio: 1 / 1;
    }

    .cardContent {
      padding: 15px 14px 16px;
    }

    .serviceList {
      margin-top: 13px;
      padding: 12px 0;
      gap: 6px;
    }

    .servicePill {
      min-height: 27px;
      padding-inline: 8px;
      font-size: 8.5px;
    }

    .cardFooter {
      margin-top: 13px;
      gap: 10px;
    }

    .price strong {
      font-size: 24px;
    }

    .compare {
      min-height: 34px;
      padding: 0 5px 0 10px;
      gap: 7px;
      font-size: 10px;
    }

    .compare svg {
      width: 24px;
      height: 24px;
      padding: 6px;
    }

    .desktopCompare {
      display: none !important;
    }

