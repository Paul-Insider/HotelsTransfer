---
import { destinations } from "../data/destinations";
---

<section class="destinations" aria-labelledby="destinations-title">
  <div class="sectionHeader">
    <div class="sectionIntro">
      <p class="eyebrow">Curated destinations</p>

      <h2 id="destinations-title">
        Exceptional arrivals,
        <span>wherever the world takes you.</span>
      </h2>

      <p class="sectionDescription">
        Compare carefully selected transfer partners across the world’s most
        requested destinations.
      </p>
    </div>

    <a class="viewAll" href="/destinations">
      <span>View all destinations</span>

      <svg
        viewBox="0 0 24 24"
        aria-hidden="true"
        width="16"
        height="16"
      >
        <path
          d="M7 17 17 7M8 7h9v9"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
  </div>

  <div class="destinationGrid">
    {
      destinations.map((destination) => (
        <a
          class="destinationCard"
          href={`/destinations/${destination.slug}`}
          aria-label={`Compare airport transfers in ${destination.city}`}
        >
          <div class="media">
            <div class="fallbackCode" aria-hidden="true">
              {destination.code}
            </div>

            <img
              src={destination.image}
              alt={`${destination.city}, ${destination.country}`}
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              sizes="
                (max-width: 620px) calc(100vw - 32px),
                (max-width: 900px) 50vw,
                (max-width: 1180px) 33vw,
                25vw
              "
            />

            <div class="mediaShade"></div>

            <div class="mediaTop">
              <span class="airportCode">{destination.code}</span>

              <span class="curatedBadge">
                <svg
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  width="13"
                  height="13"
                >
                  <path
                    d="m12 3 2.2 2.3 3.2-.3.7 3.1 2.8 1.7-1.4 2.9 1.4 2.9-2.8 1.7-.7 3.1-3.2-.3L12 22l-2.2-2.3-3.2.3-.7-3.1-2.8-1.7 1.4-2.9-1.4-2.9 2.8-1.7.7-3.1 3.2.3L12 3Z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linejoin="round"
                  />
                  <path
                    d="m9.3 12 1.8 1.8 3.8-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>

                Curated
              </span>
            </div>

            <div class="mediaBottom">
              <span>{destination.country}</span>
            </div>
          </div>

          <div class="cardContent">
            <div class="destinationHeading">
              <div>
                <p class="arrivalLabel">Private airport arrivals</p>
                <h3>{destination.city}</h3>
              </div>

              <span class="arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="17" height="17">
                  <path
                    d="M7 17 17 7M8 7h9v9"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </div>

            <div class="trustRow">
              <div class="rating">
                <svg
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  width="15"
                  height="15"
                >
                  <path
                    d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6.1-5.4-2.9-5.4 2.9 1-6.1-4.4-4.3 6.1-.9L12 3Z"
                    fill="currentColor"
                  />
                </svg>

                <strong>{destination.rating.toFixed(1)}</strong>
                <span>Guest rating</span>
              </div>

              <span class="divider" aria-hidden="true"></span>

              <div class="partners">
                <svg
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  width="15"
                  height="15"
                >
                  <path
                    d="M12 3 5.5 5.6v5.2c0 4.3 2.7 8.1 6.5 9.4 3.8-1.3 6.5-5.1 6.5-9.4V5.6L12 3Z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linejoin="round"
                  />
                  <path
                    d="m9.2 11.8 1.8 1.8 3.8-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>

                <strong>{destination.partners}</strong>
                <span>Verified partners</span>
              </div>
            </div>

            <div class="services" aria-label="Available transfer services">
              {
                destination.services.map((service) => (
                  <span>
                    <svg
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      width="13"
                      height="13"
                    >
                      <path
                        d="m7.5 12.2 3 3 6-6.4"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.9"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>

                    {service}
                  </span>
                ))
              }
            </div>

            <div class="cardFooter">
              <div class="price">
                <span>Transfers from</span>

                <strong>
                  ${destination.price}
                  <small>{destination.currency}</small>
                </strong>
              </div>

              <span class="compare">
                Compare transfers

                <svg
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  width="15"
                  height="15"
                >
                  <path
                    d="m9 18 6-6-6-6"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .destinations {
    max-width: 1400px;
    margin: 82px auto 112px;
    padding: 0 30px;
  }

  .sectionHeader {
    margin-bottom: 34px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .sectionIntro {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 13px;
    color: var(--blue);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    color: #101827;
    font-size: clamp(38px, 4.25vw, 58px);
    font-weight: 750;
    line-height: 0.96;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  h2 span {
    display: block;
    color: #687386;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.045em;
  }

  .sectionDescription {
    max-width: 620px;
    margin: 20px 0 0;
    color: #6b7688;
    font-size: 15px;
    line-height: 1.65;
  }

  .viewAll {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding-bottom: 3px;
    color: #123f79;
    border-bottom: 1px solid rgba(18, 63, 121, 0.24);
    font-size: 13px;
    font-weight: 800;
  }

  .destinationGrid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .destinationCard {
    min-width: 0;
    display: block;
    overflow: hidden;
    color: #111b2d;
    border: 1px solid rgba(15, 23, 42, 0.075);
    border-radius: 24px;
    background:
      linear-gradient(180deg, #ffffff 0%, #fdfdfc 100%);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.025),
      0 16px 42px rgba(15, 23, 42, 0.055);
    content-visibility: auto;
    contain-intrinsic-size: 500px;
    transition:
      transform 260ms cubic-bezier(0.2, 0.75, 0.25, 1),
      border-color 260ms ease,
      box-shadow 260ms ease;
  }

  .destinationCard:hover {
    transform: translateY(-6px);
    border-color: rgba(29, 75, 134, 0.16);
    box-shadow:
      0 2px 4px rgba(15, 23, 42, 0.025),
      0 30px 70px rgba(15, 23, 42, 0.13);
  }

  .media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background:
      radial-gradient(circle at 22% 15%, #f4eee4, transparent 45%),
      linear-gradient(145deg, #f3f6f8, #e8edf1);
  }

  .fallbackCode {
    position: absolute;
    right: -10px;
    bottom: -24px;
    z-index: 0;
    color: rgba(19, 36, 61, 0.055);
    font-size: 90px;
    font-weight: 900;
    letter-spacing: -0.08em;
  }

  .media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 700ms cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  .destinationCard:hover .media img {
    transform: scale(1.035);
  }

  .mediaShade {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        rgba(7, 14, 24, 0.12) 0%,
        transparent 42%,
        rgba(7, 14, 24, 0.53) 100%
      );
    pointer-events: none;
  }

  .mediaTop {
    position: absolute;
    top: 15px;
    left: 15px;
    right: 15px;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .airportCode,
  .curatedBadge {
    min-height: 29px;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 8px 20px rgba(5, 16, 29, 0.13);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .airportCode {
    padding: 0 10px;
    color: #162944;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.09em;
  }

  .curatedBadge {
    gap: 5px;
    padding: 0 9px;
    color: #263b55;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .mediaBottom {
    position: absolute;
    left: 16px;
    right: 16px;
    bottom: 15px;
    z-index: 3;
    color: white;
    font-size: 11px;
    font-weight: 750;
    letter-spacing: 0.025em;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.5);
  }

  .cardContent {
    padding: 21px 21px 20px;
  }

  .destinationHeading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .arrivalLabel {
    margin: 0 0 6px;
    color: #7b8493;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    color: #101827;
    font-size: 27px;
    font-weight: 760;
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .arrow {
    flex: 0 0 auto;
    width: 37px;
    height: 37px;
    display: grid;
    place-items: center;
    color: #123f79;
    border: 1px solid rgba(18, 63, 121, 0.08);
    border-radius: 50%;
    background: #f1f6fc;
    transition:
      color 220ms ease,
      background 220ms ease,
      transform 220ms ease;
  }

  .destinationCard:hover .arrow {
    color: white;
    background: #123f79;
    transform: translate(2px, -2px);
  }

  .trustRow {
    margin-top: 20px;
    padding: 15px 0;
    display: grid;
    grid-template-columns: 1fr 1px 1.35fr;
    align-items: center;
    gap: 13px;
    border-top: 1px solid rgba(15, 23, 42, 0.065);
    border-bottom: 1px solid rgba(15, 23, 42, 0.065);
  }

  .rating,
  .partners {
    min-width: 0;
    display: grid;
    grid-template-columns: auto auto;
    align-items: center;
    justify-content: start;
    column-gap: 5px;
  }

  .rating svg {
    color: #b58a42;
  }

  .partners svg {
    color: #315b8c;
  }

  .rating strong,
  .partners strong {
    color: #172238;
    font-size: 13px;
    font-weight: 850;
  }

  .rating span,
  .partners span {
    grid-column: 1 / -1;
    margin-top: 4px;
    color: #7a8494;
    font-size: 9px;
    font-weight: 650;
    white-space: nowrap;
  }

  .divider {
    width: 1px;
    height: 30px;
    background: rgba(15, 23, 42, 0.08);
  }

  .services {
    min-height: 30px;
    margin-top: 15px;
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .services span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 7px 8px;
    color: #536072;
    border: 1px solid rgba(15, 23, 42, 0.07);
    border-radius: 999px;
    background: #f8fafb;
    font-size: 9px;
    font-weight: 700;
    white-space: nowrap;
  }

  .services svg {
    color: #315b8c;
  }

  .cardFooter {
    margin-top: 18px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 15px;
  }

  .price {
    display: grid;
    gap: 4px;
  }

  .price > span {
    color: #7b8493;
    font-size: 9px;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .price strong {
    color: #101827;
    font-size: 21px;
    font-weight: 820;
    letter-spacing: -0.045em;
  }

  .price small {
    margin-left: 3px;
    color: #7b8493;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .compare {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #123f79;
    font-size: 10px;
    font-weight: 850;
    white-space: nowrap;
  }

  @media (max-width: 1180px) {
    .destinationGrid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .destinations {
      margin-top: 68px;
      padding-inline: 20px;
    }

    .sectionHeader {
      align-items: flex-start;
      flex-direction: column;
      gap: 20px;
    }

    .destinationGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .destinations {
      margin: 58px auto 80px;
      padding-inline: 16px;
    }

    .sectionHeader {
      margin-bottom: 25px;
    }

    h2 {
      font-size: clamp(38px, 11vw, 47px);
      line-height: 0.98;
    }

    .sectionDescription {
      margin-top: 17px;
      font-size: 14px;
      line-height: 1.6;
    }

    .viewAll {
      font-size: 12px;
    }

    .destinationGrid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .destinationCard {
      border-radius: 22px;
    }

    .media {
      aspect-ratio: 1.3 / 1;
    }

    .cardContent {
      padding: 21px 20px 20px;
    }

    h3 {
      font-size: 29px;
    }

    .trustRow {
      grid-template-columns: 1fr 1px 1.25fr;
    }

    .services {
      gap: 6px;
    }

    .services span {
      padding: 7px 9px;
      font-size: 9px;
    }

    .compare {
      font-size: 10px;
    }
  }

  @media (max-width: 380px) {
    .cardFooter {
      align-items: flex-start;
      flex-direction: column;
    }

    .compare {
      padding-top: 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .destinationCard,
    .media img,
    .arrow {
      transition: none;
    }

    .destinationCard:hover,
    .destinationCard:hover .media img,
    .destinationCard:hover .arrow {
      transform: none;
    }
  }
</style>
