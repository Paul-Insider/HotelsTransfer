<section class="hero">
  <picture class="heroMedia">
    <source
      media="(max-width: 767px)"
      srcset="/images/hero/hero-global-mobility-mobile.webp"
    />

    <img
      src="/images/hero/hero-global-mobility.webp"
      alt=""
      width="2400"
      height="1350"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  <div class="heroOverlay"></div>

  <header class="nav">
    <a class="brand" href="/" aria-label="HotelsTransfer home">
      HotelsTransfer
    </a>

    <nav aria-label="Primary navigation">
      <a href="/destinations">Destinations</a>
      <a href="/airports">Airports</a>
      <a href="/companies">Private Partners</a>
      <a href="/how-it-works">How it works</a>
    </nav>

    <div class="navActions">
      <a class="login" href="/login">Log in</a>
      <a class="bookButton" href="#transfer-search">Book a transfer</a>
    </div>
  </header>

  <div class="heroContent">
    <p class="eyebrow">The world’s private mobility network</p>

    <h1>
      Compare private airport transfers
      <span>in over 1,100 destinations.</span>
    </h1>

    <p class="lead">
      Trusted local companies, clear prices and professional drivers, from
      airport arrival to hotel door.
    </p>

    <form
      id="transfer-search"
      class="searchCapsule"
      aria-label="Search airport transfers"
    >
      <label class="searchField pickupField">
        <span>Pickup airport</span>
        <input
          type="search"
          name="pickup"
          placeholder="Select pickup airport"
          autocomplete="off"
        />
      </label>

      <label class="searchField destinationField">
        <span>Destination</span>
        <input
          type="search"
          name="destination"
          placeholder="Hotel, address or destination"
          autocomplete="off"
        />
      </label>

      <label class="searchField dateField">
        <span>Date</span>
        <input type="date" name="date" />
      </label>

      <label class="searchField passengersField">
        <span>Passengers</span>
        <select name="passengers">
          <option value="1">1 passenger</option>
          <option value="2">2 passengers</option>
          <option value="3">3 passengers</option>
          <option value="4">4 passengers</option>
          <option value="5">5+ passengers</option>
        </select>
      </label>

      <button type="submit">
        <span>Search transfers</span>
        <span class="searchArrow" aria-hidden="true">→</span>
      </button>
    </form>

    <ul class="trustIndicators" aria-label="Transfer service highlights">
      <li>Professional drivers</li>
      <li>Flight monitored</li>
      <li>Meet &amp; greet</li>
      <li>Fixed pricing</li>
    </ul>
  </div>
</section>

