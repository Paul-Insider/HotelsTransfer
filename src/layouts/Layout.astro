---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

const {
  title = "HotelsTransfer - Premium Airport Transfers Worldwide",
  description = "Compare and book trusted airport transfer companies worldwide.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Footer />
  </body>
</html>
